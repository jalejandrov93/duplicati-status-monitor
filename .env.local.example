# MongoDB Atlas URI
# Reemplaza con tu URI real de MongoDB Atlas
# Formato: mongodb+srv://usuario:contraseña@cluster.mongodb.net/LTSM?retryWrites=true&w=majority
#
# Base de datos: LTSM
# Colección: duplicati (se configura automáticamente en el código)

MONGODB_URI=mongodb+srv://usuario:contraseña@cluster.mongodb.net/LTSM?retryWrites=true&w=majority

# Para MongoDB local (alternativa):
# MONGODB_URI=mongodb://localhost:27017/LTSM
